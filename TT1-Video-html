let filtered = [...ALL_DATA];
let displayed = 0;
const PAGE = 100;
let activeFilters = {cat:'ALL', eg:'ALL', month:'ALL'};
let currentSort = 'imp';

const CAT_LABELS = {Live:'Live Room',ShortVideo:'Short Video',AI:'AI',Official:'Official'};
const EG_DISPLAY = {'🍀':'🍀','❤️':'❤️','🔥':'🔥','💅':'💅','✨':'✨','AI':'🤖','Official':'📢','Other':'Other'};

function roiClass(r){return r>=1.8?'roi-hi':r>=1.4?'roi-mid':'roi-lo';}
function fmtK(v){return v>=1000000?(v/1000000).toFixed(1)+'M':v>=1000?(v/1000).toFixed(1)+'K':v;}
function fmtD(v){return '$'+(v>=1000?(v/1000).toFixed(1)+'K':v.toFixed(0));}

function setFilter(type, val, btn){
  activeFilters[type] = val;
  const groupId = type==='cat'?'cat-filters':type==='eg'?'emoji-filters':'month-filters';
  document.querySelectorAll('#'+groupId+' .fbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function sortBy(col){
  currentSort = col;
  document.querySelectorAll('.sort-arrow').forEach(a=>a.textContent='');
  document.getElementById('arr-'+col).textContent='↓';
  // update select
  const sel = document.getElementById('sort-select');
  if([...sel.options].some(o=>o.value===col)) sel.value=col;
  applyFilters();
}

function applyFilters(){
  const search = document.getElementById('search-input').value.trim().toLowerCase();
  const sortCol = document.getElementById('sort-select').value;
  currentSort = sortCol;
  document.querySelectorAll('.sort-arrow').forEach(a=>a.textContent='');
  const arrEl = document.getElementById('arr-'+sortCol);
  if(arrEl) arrEl.textContent='↓';

  filtered = ALL_DATA.filter(d=>{
    if(activeFilters.cat!=='ALL' && d.cat!==activeFilters.cat) return false;
    if(activeFilters.eg!=='ALL' && d.eg!==activeFilters.eg) return false;
    if(activeFilters.month!=='ALL' && !d.months.includes(activeFilters.month)) return false;
    if(search){
      const q=search.toLowerCase();
      if(!d.title.toLowerCase().includes(q) && !d.id.includes(q)) return false;
    }
    return true;
  });

  filtered.sort((a,b)=>b[sortCol]-a[sortCol]);
  displayed = 0;
  document.getElementById('table-body').innerHTML='';
  document.getElementById('stats-text').innerHTML=`<b>${filtered.length}</b> creatives`;
  renderRows();
}

function renderRows(){
  const body = document.getElementById('table-body');
  const slice = filtered.slice(displayed, displayed+PAGE);
  const empty = document.getElementById('empty-msg');
  const btn = document.getElementById('load-more-btn');

  if(filtered.length===0){empty.style.display='block';btn.style.display='none';return;}
  empty.style.display='none';

  slice.forEach(d=>{
    const months = d.months.split(',').map(m=>m.replace('2026-',''));
    const monthChips = months.map(m=>`<span class="mc">${m}</span>`).join('');
    const egLabel = EG_DISPLAY[d.eg]||d.eg||'';
    const tr = document.createElement('tr');
    tr.innerHTML=`
      <td class="title-cell">
        <div class="title-text" title="${d.title.replace(/"/g,'&quot;')}">${d.title||'(no title)'}</div>
        <div class="post-id">
          <span style="color:#333">#</span>${d.id}
          <button class="copy-btn" onclick="copyId(this,'${d.id}')">copy</button>
        </div>
      </td>
      <td>
        <span class="eg-badge">${egLabel}</span>
        <span class="cat-badge badge-${d.cat}">${CAT_LABELS[d.cat]||d.cat}</span>
      </td>
      <td>${fmtK(d.imp)}</td>
      <td>${fmtD(d.cost)}</td>
      <td>${fmtD(d.rev)}</td>
      <td class="${roiClass(d.roi)}">${d.roi||'-'}</td>
      <td>${d.ctr||'-'}%</td>
      <td>${d.cvr||'-'}%</td>
      <td>${d.entry||'-'}%</td>
      <td>${d.ret10||'-'}%</td>
      <td><div class="month-chips">${monthChips}</div></td>
    `;
    body.appendChild(tr);
  });

  displayed += slice.length;
  btn.style.display = displayed < filtered.length ? 'block' : 'none';
  btn.textContent = `Load 100 more ↓ (Showing ${displayed}/${filtered.length})`;
}

function loadMore(){renderRows();}

function copyId(btn, id){
  navigator.clipboard.writeText(id).then(()=>{
    btn.textContent='✓';btn.classList.add('copied');
    setTimeout(()=>{btn.textContent='copy';btn.classList.remove('copied');},1500);
  });
}

// init
applyFilters();
</script>
